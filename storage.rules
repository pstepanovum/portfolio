rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Public portfolio assets.
    // Reads are public because these are the images used on the live site.
    // Writes stay admin-only.
    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certifications/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Lock down everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
